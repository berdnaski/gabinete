generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
  CITIZEN
}

enum CabinetRole {
  OWNER
  STAFF
}

enum DemandStatus {
  SUBMITTED
  IN_ANALYSIS
  IN_PROGRESS
  RESOLVED
  REJECTED
  CANCELED
}

enum DemandPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ResultType {
  INFRASTRUCTURE
  SOCIAL
  LEGISLATIVE
  OTHER
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  phone      String?
  avatarUrl  String?   @map("avatar_url")
  role       UserRole  @default(CITIZEN)
  hasSetPassword Boolean @default(true) @map("has_set_password")

  address      String?
  zipcode      String?
  neighborhood String?
  city         String?
  state        String?
  lat          Float?
  long         Float?

  isVerified Boolean   @default(false) @map("is_verified")
  disabledAt DateTime? @map("disabled_at")

  accounts        Account[]
  cabinetMembers  CabinetMember[]
  reportedDemands Demand[]        @relation("DemandReporter")
  demandLikes     DemandLike[]
  demandComments  DemandComment[]
  tokens          Token[]
  notifications   Notification[]

  @@index([disabledAt])
  @@map("users")
}

model Account {
  id                String @id @default(uuid())
  userId            String @map("user_id")
  provider          String
  providerAccountId String @map("provider_account_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Cabinet {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  email       String?
  description String?
  avatarUrl   String?   @map("avatar_url")
  disabledAt  DateTime? @map("disabled_at")
  score             Int @default(0)
  in_progress_count Int @default(0) @map("in_progress_count")
  resolved_count    Int @default(0) @map("resolved_count")

  members CabinetMember[]
  demands Demand[]
  results Result[]
  invitations CabinetInvitation[]

  @@index([slug])
  @@index([disabledAt])
  @@map("cabinets")
}

model CabinetMember {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  cabinetId String      @map("cabinet_id")
  role      CabinetRole @default(STAFF)

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cabinet         Cabinet  @relation(fields: [cabinetId], references: [id])
  assignedDemands Demand[] @relation("DemandAssignee")

  @@unique([userId, cabinetId])
  @@index([userId])
  @@index([cabinetId])
  @@map("cabinet_members")
}

model CabinetInvitation {
  id        String      @id @default(uuid())
  email     String
  token     String      @unique
  cabinetId String      @map("cabinet_id")
  role      CabinetRole @default(STAFF)
  expiresAt DateTime    @map("expires_at")
  createdAt DateTime    @default(now()) @map("created_at")

  cabinet Cabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)

  @@unique([email, cabinetId])
  @@index([email])
  @@index([token])
  @@map("cabinet_invitations")
}

model Category {
  id         String    @id @default(uuid())
  name       String
  slug       String
  disabledAt DateTime? @map("disabled_at")

  demands Demand[]

  @@index([slug])
  @@index([disabledAt])
  @@map("categories")
}

model Demand {
  id               String         @id @default(uuid())
  title            String
  description      String
  status           DemandStatus   @default(SUBMITTED)
  priority         DemandPriority @default(LOW)
  address          String
  zipcode          String?
  lat              Float?
  long             Float?
  neighborhood     String
  city             String
  state            String
  reporterId       String?        @map("reporter_id")
  guestEmail       String?        @map("guest_email")
  cabinetId        String?        @map("cabinet_id")
  categoryId       String?        @map("category_id")
  assigneeMemberId String?        @map("assignee_member_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  disabledAt       DateTime?      @map("disabled_at")

  reporter       User?            @relation("DemandReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  cabinet        Cabinet?         @relation(fields: [cabinetId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  assigneeMember CabinetMember?   @relation("DemandAssignee", fields: [assigneeMemberId], references: [id])
  evidences DemandEvidence[]
  likes     DemandLike[]
  comments  DemandComment[]
  results   Result[]

  @@index([cabinetId])
  @@index([categoryId])
  @@index([status])
  @@index([city])
  @@index([disabledAt])
  @@map("demands")
}

model DemandEvidence {
  id         String @id @default(uuid())
  storageKey String @map("storage_key")
  url        String
  mimeType   String @map("mime_type")
  size       Int?
  demandId   String @map("demand_id")

  demand Demand @relation(fields: [demandId], references: [id])

  @@map("demand_evidences")
}

model DemandLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  demandId  String   @map("demand_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  demand Demand @relation(fields: [demandId], references: [id])

  @@unique([userId, demandId])
  @@index([demandId])
  @@map("demand_likes")
}

model DemandComment {
  id                String   @id @default(uuid())
  content           String
  isCabinetResponse Boolean  @default(false) @map("is_cabinet_response")
  demandId          String   @map("demand_id")
  authorId          String   @map("author_id")
  createdAt         DateTime @default(now()) @map("created_at")

  demand Demand @relation(fields: [demandId], references: [id])
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([demandId])
  @@map("demand_comments")
}

model Result {
  id                   String    @id @default(uuid())
  title                String
  description          String
  type                 ResultType
  cabinetId            String    @map("cabinet_id")
  demandId             String?   @map("demand_id")
  protocolFileKey      String?   @map("protocol_file_key")
  protocolFileUrl      String?   @map("protocol_file_url")
  protocolFileName     String?   @map("protocol_file_name")
  protocolFileMimeType String?   @map("protocol_file_mime_type")
  protocolFileSize     Int?      @map("protocol_file_size")
  createdAt            DateTime  @default(now()) @map("created_at")
  disabledAt           DateTime? @map("disabled_at")

  cabinet Cabinet       @relation(fields: [cabinetId], references: [id])
  demand  Demand?       @relation(fields: [demandId], references: [id])
  images  ResultImage[]

  @@index([cabinetId])
  @@index([disabledAt])
  @@map("results")
}

model ResultImage {
  id         String @id @default(uuid())
  url        String
  storageKey String @map("storage_key")
  resultId   String @map("result_id")

  result Result @relation(fields: [resultId], references: [id])

  @@index([resultId])
  @@map("result_images")
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
  CHANGE_PASSWORD
  REFRESH_TOKEN
}

model Token {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      TokenType
  payload   String?
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("tokens")
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  link      String?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  userId    String           @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
