generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
}

enum CabinetRole {
  OWNER
  STAFF
}

enum DemandStatus {
  SUBMITTED
  IN_ANALYSIS
  IN_PROGRESS
  RESOLVED
  REJECTED
  CANCELED
}

enum DemandPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ResultType {
  INFRASTRUCTURE
  SOCIAL
  LEGISLATIVE
  OTHER
}

enum ResultImageType {
  BEFORE
  AFTER
  GENERAL
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  avatarUrl  String?   @map("avatar_url")
  role       UserRole  @default(MEMBER)
  isVerified Boolean   @default(false) @map("is_verified")
  disabledAt DateTime? @map("disabled_at")

  accounts        Account[]
  cabinetMembers  CabinetMember[]
  reportedDemands Demand[]        @relation("DemandReporter")
  demandLikes     DemandLike[]
  demandComments  DemandComment[]
  tokens          Token[]

  @@index([disabledAt])
  @@map("users")
}

model Account {
  id                String @id @default(cuid())
  userId            String @map("user_id")
  provider          String
  providerAccountId String @map("provider_account_id")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Cabinet {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  avatarUrl   String?   @map("avatar_url")
  disabledAt  DateTime? @map("disabled_at")

  members CabinetMember[]
  demands Demand[]
  results Result[]

  @@index([slug])
  @@index([disabledAt])
  @@map("cabinets")
}

model CabinetMember {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  cabinetId String      @map("cabinet_id")
  role      CabinetRole @default(STAFF)

  user            User     @relation(fields: [userId], references: [id])
  cabinet         Cabinet  @relation(fields: [cabinetId], references: [id])
  assignedDemands Demand[] @relation("DemandAssignee")

  @@unique([userId, cabinetId])
  @@index([userId])
  @@index([cabinetId])
  @@map("cabinet_members")
}

model Category {
  id         String    @id @default(cuid())
  name       String
  slug       String
  disabledAt DateTime? @map("disabled_at")

  demands Demand[]

  @@index([slug])
  @@index([disabledAt])
  @@map("categories")
}

model Demand {
  id               String         @id @default(cuid())
  title            String
  description      String
  status           DemandStatus   @default(SUBMITTED)
  priority         DemandPriority @default(LOW)
  address          String
  zipcode          String
  lat              Float?
  long             Float?
  neighborhood     String
  city             String
  state            String
  reporterId       String?        @map("reporter_id")
  guestEmail       String?        @map("guest_email")
  cabinetId        String?        @map("cabinet_id")
  categoryId       String?        @map("category_id")
  assigneeMemberId String?        @map("assignee_member_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  disabledAt       DateTime?      @map("disabled_at")

  reporter       User?            @relation("DemandReporter", fields: [reporterId], references: [id])
  cabinet        Cabinet?         @relation(fields: [cabinetId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  assigneeMember CabinetMember?   @relation("DemandAssignee", fields: [assigneeMemberId], references: [id])
  evidences      DemandEvidence[]
  likes          DemandLike[]
  comments       DemandComment[]
  results        Result[]

  @@index([cabinetId])
  @@index([categoryId])
  @@index([status])
  @@index([city])
  @@index([disabledAt])
  @@map("demands")
}

model DemandEvidence {
  id         String @id @default(cuid())
  storageKey String @map("storage_key")
  url        String
  mimeType   String @map("mime_type")
  size       Int?
  demandId   String @map("demand_id")

  demand Demand @relation(fields: [demandId], references: [id])

  @@map("demand_evidences")
}

model DemandLike {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  demandId  String   @map("demand_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  demand Demand @relation(fields: [demandId], references: [id])

  @@unique([userId, demandId])
  @@index([demandId])
  @@map("demand_likes")
}

model DemandComment {
  id                String   @id @default(cuid())
  content           String
  isCabinetResponse Boolean  @default(false) @map("is_cabinet_response")
  demandId          String   @map("demand_id")
  authorId          String   @map("author_id")
  createdAt         DateTime @default(now()) @map("created_at")

  demand Demand @relation(fields: [demandId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([demandId])
  @@map("demand_comments")
}

model Result {
  id          String     @id @default(cuid())
  title       String
  description String
  type        ResultType
  isPublic    Boolean    @default(false) @map("is_public")
  cabinetId   String     @map("cabinet_id")
  demandId    String?    @map("demand_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  disabledAt  DateTime?  @map("disabled_at")

  cabinet Cabinet       @relation(fields: [cabinetId], references: [id])
  demand  Demand?       @relation(fields: [demandId], references: [id])
  images  ResultImage[]

  @@index([cabinetId])
  @@index([disabledAt])
  @@map("results")
}

model ResultImage {
  id         String          @id @default(cuid())
  url        String
  storageKey String          @map("storage_key")
  type       ResultImageType
  resultId   String          @map("result_id")

  result Result @relation(fields: [resultId], references: [id])

  @@map("result_images")
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

model Token {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("tokens")
}
